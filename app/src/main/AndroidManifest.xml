package com.sockc.unicomhook;

import de.robv.android.xposed.IXposedHookLoadPackage;
import de.robv.android.xposed.XC_MethodHook;
import de.robv.android.xposed.XposedBridge;
import de.robv.android.xposed.XposedHelpers;
import de.robv.android.xposed.callbacks.XC_LoadPackage.LoadPackageParam;

public class MainHook implements IXposedHookLoadPackage {

    // 核心法宝：线程局部变量，用来标记当前线程正在处理的请求是不是目标 URL
    private static final ThreadLocal<Boolean> isTargetRequest = new ThreadLocal<>();

    @Override
    public void handleLoadPackage(final LoadPackageParam lpparam) throws Throwable {
        // 只针对联通 APP
        if (!lpparam.packageName.equals("com.sinovatech.unicom.ui")) {
            return;
        }

        XposedBridge.log("UnicomHook: 完美版已启动，开始精准狙击");

        // 第一步：在发起请求时，精准捕获 URL
        try {
            XposedHelpers.findAndHookMethod(
                "okhttp3.RealCall", 
                lpparam.classLoader, 
                "getResponseWithInterceptorChain", 
                new XC_MethodHook() {
                    @Override
                    protected void beforeHookedMethod(MethodHookParam param) throws Throwable {
                        try {
                            // 获取当前的 Request 对象并读取 URL
                            Object request = XposedHelpers.callMethod(param.thisObject, "request");
                            Object urlObj = XposedHelpers.callMethod(request, "url");
                            String url = urlObj.toString();
                            
                            // 只有 URL 是查询白名单时，才打上“准许修改”的标记
                            if (url != null && url.contains("checkOfficialWhitePhone")) {
                                isTargetRequest.set(true);
                                XposedBridge.log("UnicomHook: 发现目标请求，准备替换响应");
                            } else {
                                isTargetRequest.set(false);
                            }
                        } catch (Throwable t) {
                            // 忽略获取 URL 时的异常，防止应用崩溃
                            isTargetRequest.set(false);
                        }
                    }
                }
            );
        } catch (Throwable t) {
            XposedBridge.log("UnicomHook: 拦截 RealCall 失败");
        }

        // 第二步：在解析结果时，只修改带有标记的请求
        try {
            XposedHelpers.findAndHookMethod(
                "okhttp3.ResponseBody", 
                lpparam.classLoader, 
                "string", 
                new XC_MethodHook() {
                    @Override
                    protected void afterHookedMethod(MethodHookParam param) throws Throwable {
                        // 检查当前线程是否带有目标标记
                        Boolean isTarget = isTargetRequest.get();
                        
                        if (isTarget != null && isTarget) {
                            String result = (String) param.getResult();
                            if (result != null) {
                                // 执行精确替换
                                String modified = result.replaceAll("\"respCode\"\\s*:\\s*(\"[^\"]*\"|[^,\\}\\]\\s]+)", "\"respCode\":\"0000\"");
                                modified = modified.replaceAll("\"isOpen\"\\s*:\\s*(\"[^\"]*\"|[^,\\}\\]\\s]+)", "\"isOpen\":\"1\"");
                                modified = modified.replaceAll("\"status\"\\s*:\\s*(\"[^\"]*\"|[^,\\}\\]\\s]+)", "\"status\":\"1\"");
                                
                                param.setResult(modified);
                                XposedBridge.log("UnicomHook: 替换 0000 成功，放行！");
                            }
                            // 用完立刻复位，绝不污染下一个网络请求
                            isTargetRequest.set(false);
                        }
                    }
                }
            );
        } catch (Throwable t) {
            XposedBridge.log("UnicomHook: 拦截 ResponseBody 失败");
        }
    }
}
        
